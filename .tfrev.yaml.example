# .tfrev.yaml — tfrev configuration
# Place this file in your Terraform project root.

# AI provider: "anthropic" (default) or "aws-bedrock"
#
# anthropic  — calls the Anthropic API directly.
#              Requires: ANTHROPIC_API_KEY environment variable.
#
# aws-bedrock — calls Claude through AWS Bedrock.
#               Requires: boto3 installed (`pip install 'tfrev[aws]'`) and
#               standard AWS credentials (env vars, ~/.aws/credentials, or IAM role).
#               The model value must be a Bedrock model ID, e.g.:
#                 anthropic.claude-sonnet-4-5-20250514-v1:0
#
provider: anthropic

# Claude model to use for reviews
model: claude-sonnet-4-6

# Maximum response tokens
max_tokens: 4096

# Minimum severity to include in output (info, low, medium, high, critical)
severity_threshold: low

# Exit code 1 if any finding is at or above this severity
fail_on: high

# Custom review policies — these are checked in addition to the built-in rules
policies:
  - name: no-public-ingress
    description: "Flag any security group rule allowing ingress from 0.0.0.0/0"
    severity: critical

  - name: blast-radius-limit
    description: "Flag if more than 10 resources are being modified in a single plan"
    threshold: 10
    severity: high

  - name: require-standard-tags
    description: "All resources must have Environment, Team, and CostCenter tags"
    required_tags: ["Environment", "Team", "CostCenter"]
    severity: medium

  - name: no-hardcoded-images
    description: "Machine image IDs (AMIs, GCE images, etc.) should come from data sources, not hardcoded strings"
    severity: low

# Resources that should always receive extra scrutiny
# Supports glob patterns
sensitive_resources:
  # AWS
  - aws_iam_*
  - aws_security_group*
  - aws_kms_key
  - aws_s3_bucket_policy
  - aws_rds_cluster
  - aws_db_instance
  - aws_route53_zone
  # GCP
  - google_project_iam_*
  - google_compute_firewall*
  - google_kms_*
  - google_sql_database_instance
  # Azure
  - azurerm_key_vault*
  - azurerm_network_security_group*
  - azurerm_role_assignment
  - azurerm_mssql_server
  # Kubernetes
  - kubernetes_cluster_role*
  - kubernetes_network_policy

# Files to ignore in the diff (glob patterns)
ignore:
  - "*.auto.tfvars"
  - "backend.tf"
  - ".terraform.lock.hcl"
